{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "arrowParens": "avoid",
    "bracketSameLine": false,
    "bracketSpacing": true,
    "ignorePatterns": ["**/dist/**", "src/generated/**", "test-ledger/**"],
    "jsxSingleQuote": false,
    "overrides": [
        {
            "files": ["*.yaml", "*.yml"],
            "options": { "tabWidth": 2 }
        }
    ],
    "printWidth": 120,
    "quoteProps": "as-needed",
    "semi": true,
    "singleQuote": true,
    "sortImports": true,
    "tabWidth": 4,
    "useTabs": false
}
